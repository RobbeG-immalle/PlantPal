rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function belongsToHousehold(householdId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // --- Users ---
    match /users/{userId} {
      // Owner can always read their own profile.
      // Other signed-in users can read profiles (needed to display household member names).
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // --- Households ---
    match /households/{householdId} {
      // Members can read their household. Also allow any signed-in user to read
      // so the join-by-invite-code flow can fetch household details.
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      // Members can update (e.g. add new members via invite). Also allow a user
      // who is being added to memberIds (join flow) to update.
      allow update: if isSignedIn()
        && (belongsToHousehold(householdId)
            || request.auth.uid in request.resource.data.memberIds);
      allow delete: if isSignedIn()
        && get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid;
    }

    // --- Plants (scoped to household) ---
    match /plants/{plantId} {
      allow read: if isSignedIn()
        && belongsToHousehold(resource.data.householdId);
      allow create: if isSignedIn()
        && belongsToHousehold(request.resource.data.householdId);
      allow update: if isSignedIn()
        && belongsToHousehold(resource.data.householdId);
      allow delete: if isSignedIn()
        && belongsToHousehold(resource.data.householdId);

      // Growth entries subcollection
      match /growthEntries/{entryId} {
        allow read: if isSignedIn()
          && belongsToHousehold(get(/databases/$(database)/documents/plants/$(plantId)).data.householdId);
        allow create: if isSignedIn()
          && belongsToHousehold(get(/databases/$(database)/documents/plants/$(plantId)).data.householdId);
        allow delete: if isSignedIn()
          && belongsToHousehold(get(/databases/$(database)/documents/plants/$(plantId)).data.householdId);
      }
    }

    // --- Invitations ---
    match /invitations/{invitationId} {
      // Anyone signed in can read an invitation (needed to join via code)
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && belongsToHousehold(request.resource.data.householdId);
      allow delete: if isSignedIn()
        && belongsToHousehold(resource.data.householdId);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
